# Auto detect text files and perform LF normalization
* text=auto

# JavaScript files
*.js text eol=lf
*.json text eol=lf

# HTML files
*.html text eol=lf

# CSS files
*.css text eol=lf

# Markdown files
*.md text eol=lf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Lock files
package-lock.json -diff 